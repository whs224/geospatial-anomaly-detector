# Copy to .env and adjust. Every value has a working default for local use.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geospatial_db

# OpenSky OAuth2 client credentials (optional but recommended).
# Anonymous access gets ~400 API credits/day; a free registered account gets
# 4000. Create an API client at https://opensky-network.org under
# Account > API Client, then paste the credentials here.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Ingestion cadence in seconds. The default NYC metro bounding box costs
# 1 API credit per request; 10s keeps the map near-real-time on an
# authenticated account.
FETCH_INTERVAL_SECONDS=10

# Hours of position history to keep.
RETENTION_HOURS=24
